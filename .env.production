# Kirby Production Environment Configuration
# Copy this to .env on your production server and update the values

# Environment
ENVIRONMENT=production

# Database Configuration
POSTGRES_DB=kirby
POSTGRES_USER=kirby_user
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
DB_PORT=5432

# API Configuration
API_PORT=8000
API_WORKERS=2
LOG_LEVEL=INFO
LOG_FORMAT=json

# Collector Configuration
COLLECTOR_HEARTBEAT_INTERVAL=30
COLLECTOR_RECONNECT_DELAY=5
COLLECTOR_MAX_RECONNECT_ATTEMPTS=10
