# Database Configuration
DATABASE_URL=postgresql+asyncpg://kirby_user:your_password_here@localhost:5432/kirby
ASYNCPG_URL=postgresql://kirby_user:your_password_here@localhost:5432/kirby

# Database Credentials (for Docker Compose)
POSTGRES_DB=kirby
POSTGRES_USER=kirby_user
POSTGRES_PASSWORD=your_password_here
DB_PORT=5432

# Database Pool Configuration
DB_POOL_MIN_SIZE=10
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Collector Configuration
COLLECTOR_HEARTBEAT_INTERVAL=30
COLLECTOR_RECONNECT_DELAY=5
COLLECTOR_MAX_RECONNECT_ATTEMPTS=10

# Backfill Configuration
BACKFILL_BATCH_SIZE=1000
BACKFILL_RATE_LIMIT_DELAY=1000

# Application Environment
ENVIRONMENT=development  # development, staging, production
